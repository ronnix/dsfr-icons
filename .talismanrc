# Faux positifs Talisman :
# - package-lock.json : hash d'intégrité sha512 de npm (pas des secrets) — suivi par checksum
# - src/app.js : faux positif sur du code (gestion des touches clavier au keydown).
#   JS client public, qui ne contient par nature aucun secret → on désactive le scan
#   de contenu pour ce fichier (par nom, sans checksum, pas de friction à l'édition).
fileignoreconfig:
  - filename: package-lock.json
    checksum: 133bb05282765c38352c355672d5f806268089623bfcbdda50a956bcf60e5af1
  - filename: src/app.js
    ignore_detectors:
      - filecontent
version: "1.0"
